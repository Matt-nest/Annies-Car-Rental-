# ═══════════════════════════════════════════════════════════════════════
# Frontend Environment Variables (Vite)
#
# These values are injected into both index.html and src/config/brand.ts
# at BUILD TIME. To set up a new white-label client, copy this file to
# .env.local and replace the values below.
# ═══════════════════════════════════════════════════════════════════════

# ── Brand Identity ───────────────────────────────────────────────────
VITE_BRAND_NAME=Annie's Car Rental
VITE_BRAND_LEGAL_NAME=Aaron's Garage LLC
VITE_BRAND_DOMAIN=anniescarrental.com

# ── Contact ──────────────────────────────────────────────────────────
VITE_BRAND_PHONE=(772) 207-1655
VITE_BRAND_EMAIL=info@anniescarrental.com

# ── Location ─────────────────────────────────────────────────────────
VITE_BRAND_CITY=Port St. Lucie
VITE_BRAND_STATE=FL
VITE_BRAND_ADDRESS=586 NW Mercantile Pl
VITE_BRAND_ZIP=34952

# ── SEO ──────────────────────────────────────────────────────────────
VITE_BRAND_META_DESCRIPTION=Premium, reliable, and family-friendly car rentals located directly in Port St. Lucie. Skip the long lines at the airport and enjoy top-tier vehicles right in your neighborhood.

# ── Visual Identity ──────────────────────────────────────────────────
VITE_BRAND_COLOR_ACCENT=#D4AF37
VITE_BRAND_COLOR_ACCENT_DARK=#B8941E

# ── External Links ───────────────────────────────────────────────────
VITE_BRAND_REVIEW_LINK=https://g.page/annies-car-rental/review
# Admin dashboard URL — the "Admin" link in the customer-site footer
VITE_BRAND_ADMIN_URL=https://admin.dashboard.anniescarrental.com

# ── Feature Flags (per-brand toggles; default off) ───────────────────
# Gate OPTIONAL behaviour on these so it stays in the shared template but
# only switches on for brands that opt in. Set to `true` to enable.
VITE_FEATURE_LOYALTY=
VITE_FEATURE_TELEMATICS=

# ── Chat Widget (leave empty to disable) ─────────────────────────────
VITE_CHAT_WIDGET_ID=69cc7589af4d34a2f6c9a3b0

# ── reCAPTCHA ────────────────────────────────────────────────────────
VITE_RECAPTCHA_SITE_KEY=

# ── Stripe ───────────────────────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=

# ── API ──────────────────────────────────────────────────
# REQUIRED: set to your backend API base URL (e.g. https://admin.dashboard.yourdomain.com/api/v1)
VITE_API_URL=

# ── Sentry (optional — error monitoring) ─────────────────────
# Backend: set in Vercel env for the API project
SENTRY_DSN=
# Dashboard: set in Vercel env for the dashboard project
VITE_SENTRY_DSN=
