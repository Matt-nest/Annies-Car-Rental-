# ═══════════════════════════════════════════════════════════════════════
# Annie's Car Rental — CUSTOMER SITE (Vercel project: annies-car-rental)
# Copy each VITE_* line into Vercel → annies-car-rental → Settings → Environment Variables
# Then redeploy. Do NOT put PORTAL_JWT_SECRET on this project.
# ═══════════════════════════════════════════════════════════════════════

VITE_API_URL=https://admin.dashboard.anniescarrental.com/api/v1
VITE_RECAPTCHA_SITE_KEY=6L_REPLACE_WITH_YOUR_V3_SITE_KEY
VITE_PAYMENT_PROVIDER=square

# Square (required for checkout + portal card on file)
VITE_SQUARE_APPLICATION_ID=sq0idp-REPLACE_WITH_YOUR_SQUARE_APP_ID
VITE_SQUARE_LOCATION_ID=LREPLACE_WITH_YOUR_SQUARE_LOCATION_ID
VITE_SQUARE_ENVIRONMENT=production

# Optional — Annie uses Square, not Stripe on the customer site
# VITE_STRIPE_PUBLISHABLE_KEY=

VITE_API_KEY=REPLACE_IF_YOU_USE_PUBLIC_BOOKING_API_KEY
VITE_CRISP_WEBSITE_ID=REPLACE_WITH_YOUR_CRISP_WEBSITE_ID
