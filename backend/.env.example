# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# API
API_PORT=3001
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
CORS_ORIGINS=https://anniescarrental.com,http://localhost:5173
# Resend (email provider)
RESEND_API_KEY=re_your-resend-api-key
RESEND_WEBHOOK_SECRET=whsec_your-resend-webhook-secret
EMAIL_FROM="Your Brand <noreply@yourdomain.com>"

# Twilio (SMS provider)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+17725551234

# Portal Auth
PORTAL_JWT_SECRET=your-portal-jwt-secret

# Cron
CRON_SECRET=your-cron-secret-for-vercel
CRON_TIMEZONE=America/New_York

# Payments
# Annie: PAYMENT_PROVIDER=square
# JD Coastal: PAYMENT_PROVIDER=stripe
PAYMENT_PROVIDER=square

# Square (Annie only)
SQUARE_ENVIRONMENT=production
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_LOCATION_ID=your-square-location-id
SQUARE_WEBHOOK_SIGNATURE_KEY=your-square-webhook-signature-key
SQUARE_WEBHOOK_URL=https://admin.dashboard.anniescarrental.com/api/v1/square/webhook

# Stripe (JD Coastal only)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# Notifications
OWNER_EMAIL=annie@anniescarrental.com
DASHBOARD_URL=https://admin.dashboard.anniescarrental.com

# Vehicle Enrichment (auto.dev)
AUTO_DEV_API_KEY=your-auto-dev-api-key

# Tax
TAX_RATE=0.07

# Bonzah Insurance API
# Sandbox: https://bonzah.sb.insillion.com — production URL: contact brandon@bonzah.com
BONZAH_API_BASE_URL=https://bonzah.sb.insillion.com
BONZAH_EMAIL=your-bonzah-account-email
BONZAH_PASSWORD=your-bonzah-account-password
