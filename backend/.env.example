# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# API
API_PORT=3001
API_KEY=your-public-api-key-for-booking-submissions
CORS_ORIGINS=https://anniescarrental.com,http://localhost:5173

# GoHighLevel Webhooks (Outbound — your backend POSTs to these)
GHL_WEBHOOK_BOOKING_CREATED=https://services.leadconnectorhq.com/hooks/...
GHL_WEBHOOK_BOOKING_APPROVED=https://services.leadconnectorhq.com/hooks/...
GHL_WEBHOOK_BOOKING_DECLINED=https://services.leadconnectorhq.com/hooks/...
GHL_WEBHOOK_BOOKING_CANCELLED=https://services.leadconnectorhq.com/hooks/...
GHL_WEBHOOK_PICKUP_REMINDER=https://services.leadconnectorhq.com/hooks/...
GHL_WEBHOOK_RETURN_REMINDER=https://services.leadconnectorhq.com/hooks/...
GHL_WEBHOOK_COMPLETED=https://services.leadconnectorhq.com/hooks/...

# Cron
CRON_TIMEZONE=America/New_York

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
