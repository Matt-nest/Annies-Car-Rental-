# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# API
API_PORT=3001
API_KEY=your-public-api-key-for-booking-submissions
CORS_ORIGINS=https://anniescarrental.com,http://localhost:5173

# GoHighLevel Webhooks (Outbound — your backend POSTs to these)
GHL_WEBHOOK_BOOKING_CREATED=https://services.leadconnectorhq.com/hooks/...
GHL_WEBHOOK_BOOKING_APPROVED=https://services.leadconnectorhq.com/hooks/...
GHL_WEBHOOK_BOOKING_DECLINED=https://services.leadconnectorhq.com/hooks/...
GHL_WEBHOOK_BOOKING_CANCELLED=https://services.leadconnectorhq.com/hooks/...
GHL_WEBHOOK_PICKUP_REMINDER=https://services.leadconnectorhq.com/hooks/...
GHL_WEBHOOK_RETURN_REMINDER=https://services.leadconnectorhq.com/hooks/...
GHL_WEBHOOK_COMPLETED=https://services.leadconnectorhq.com/hooks/...

# Cron
CRON_SECRET=your-cron-secret-for-vercel
CRON_TIMEZONE=America/New_York

# ── Payment processor ────────────────────────────────────────────────────────
# 'stripe' (default) or 'square'. Annie's runs 'square'. Selecting a processor
# activates that integration; the other stays dormant as a rollback path.
PAYMENT_PROVIDER=stripe

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# Square (used when PAYMENT_PROVIDER=square)
SQUARE_ENVIRONMENT=sandbox            # 'sandbox' or 'production'
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_APPLICATION_ID=                # also exposed to clients via GET /square/config
SQUARE_WEBHOOK_SIGNATURE_KEY=         # from the Square webhook subscription
# Optional override; defaults to the request's own URL. Set to the exact
# subscribed notification URL if behind a proxy that rewrites host/path.
SQUARE_WEBHOOK_NOTIFICATION_URL=

# Notifications
OWNER_EMAIL=annie@anniescarrental.com
DASHBOARD_URL=https://admin.dashboard.anniescarrental.com

# Vehicle Enrichment (auto.dev)
AUTO_DEV_API_KEY=your-auto-dev-api-key

# Tax
TAX_RATE=0.07

# Bonzah Insurance API
# Sandbox: https://bonzah.sb.insillion.com — production URL: contact brandon@bonzah.com
BONZAH_API_BASE_URL=https://bonzah.sb.insillion.com
BONZAH_EMAIL=your-bonzah-account-email
BONZAH_PASSWORD=your-bonzah-account-password

# Stripe publishable key (safe to expose). Served via GET /stripe/publishable-key
# so the dashboard card form always matches this account. Use the LIVE pk_ in prod.
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
