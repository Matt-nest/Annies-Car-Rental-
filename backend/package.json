{
  "name": "annies-rental-backend",
  "version": "1.0.0",
  "description": "Backend API for Annie's Car Rental",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "node db/migrate.js",
    "test": "node --test tests/*.test.js",
    "test:local": "SUPABASE_URL=http://localhost SUPABASE_SERVICE_KEY=dummy SUPABASE_ANON_KEY=dummy PAYMENT_PROVIDER=square npm test",
    "seed:staging:sql": "node scripts/generate_staging_seed_sql.mjs",
    "seed:staging:verify": "node scripts/verify_staging_seed.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.6.0",
    "node-fetch": "^3.3.2",
    "pdfkit": "^0.18.0",
    "stripe": "^22.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "nodemon": "^3.0.3",
    "pg": "^8.20.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
