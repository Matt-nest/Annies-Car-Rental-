{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.js" }
  ],
  "crons": [
    {
      "path": "/api/v1/cron/daily",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/v1/cron/auto-expire",
      "schedule": "0 */6 * * *"
    }
  ]
}
