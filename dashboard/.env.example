VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_URL=https://your-api.onrender.com/api/v1

# Payment processor — 'stripe' (default) or 'square'. Must match the backend's
# PAYMENT_PROVIDER. Annie's runs 'square'.
VITE_PAYMENT_PROVIDER=stripe

# Stripe publishable key — enables admin "take card payment over the phone" in New Booking.
# Use the same key as the customer site. Falls back to a shared test key if unset.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Square — when VITE_PAYMENT_PROVIDER=square the admin card form loads the Web
# Payments SDK config from the backend (GET /square/config); no client key needed here.
